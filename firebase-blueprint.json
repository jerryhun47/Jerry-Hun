{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Store products for YouTube automation",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string", "enum": ["Tool", "Course", "Bundle"] },
        "image_url": { "type": "string" },
        "features": { "type": "array", "items": { "type": "string" } },
        "is_active": { "type": "boolean" },
        "stock": { "type": "number" },
        "badge": { "type": "string" },
        "createdAt": { "type": "number", "description": "Timestamp" },
        "updatedAt": { "type": "number", "description": "Timestamp" }
      },
      "required": ["name", "price", "category"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer order",
      "type": "object",
      "properties": {
        "customer_name": { "type": "string" },
        "customer_email": { "type": "string" },
        "customer_phone": { "type": "string" },
        "products": { "type": "array", "items": { "type": "object" } },
        "total_price": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "delivered", "cancelled"] },
        "payment_method": { "type": "string" },
        "notes": { "type": "string" },
        "createdAt": { "type": "number", "description": "Timestamp" },
        "updatedAt": { "type": "number", "description": "Timestamp" }
      },
      "required": ["customer_name", "customer_email", "total_price", "status"]
    },
    "Contact": {
      "title": "Contact",
      "description": "Contact form submissions",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "is_read": { "type": "boolean" },
        "createdAt": { "type": "number", "description": "Timestamp" }
      },
      "required": ["name", "email", "message", "is_read"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": { "$ref": "#/entities/Product" },
      "description": "Store products"
    },
    "/orders/{orderId}": {
      "schema": { "$ref": "#/entities/Order" },
      "description": "Customer orders"
    },
    "/contacts/{contactId}": {
      "schema": { "$ref": "#/entities/Contact" },
      "description": "Pushed contact messages"
    }
  }
}
