rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Master Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitive Helpers
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    
    // We allow ANY signed-in user who exists in admins collection
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }

    match /admins/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      // Allow creation for self (to support the sign up page for owner)
      allow write: if isSignedIn() && request.auth.uid == userId; 
    }

    // Products
    function isValidProduct(data) {
      return data.size() >= 3 && data.size() <= 15
        && data.keys().hasAll(['name', 'price', 'category'])
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.price is number && data.price >= 0
        && data.category is string && data.category in ['Tool', 'Course', 'Bundle', 'all'];
    }

    match /products/{productId} {
      allow get: if isValidId(productId);
      allow list: if true; // Public list
      allow create: if true;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Orders
    function isValidOrder(data) {
       return data.size() >= 4 && data.size() <= 15
         && data.keys().hasAll(['customer_name', 'customer_email', 'total_price', 'status'])
         && data.customer_name is string && data.customer_name.size() <= 100
         && data.customer_email is string && data.customer_email.size() <= 100
         && data.total_price is number && data.total_price >= 0
         && data.status is string && data.status in ['pending', 'confirmed', 'delivered', 'cancelled', 'failed'];
    }

    match /orders/{orderId} {
      allow create: if true;
      // Only admins can see and modify orders
      allow get: if isAdmin();
      allow list: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Contacts
    function isValidContact(data) {
       return data.size() >= 4 && data.size() <= 10
         && data.keys().hasAll(['name', 'email', 'message', 'is_read'])
         && data.name is string && data.name.size() > 0 && data.name.size() <= 100
         && data.email is string && data.email.size() <= 100
         && data.message is string && data.message.size() <= 2000
         && data.is_read is bool;
    }

    match /contacts/{contactId} {
      allow create: if isValidId(contactId) && isValidContact(incoming()) && incoming().createdAt == request.time;
      // Only admins can see and modify contacts
      allow get: if isAdmin() && isValidId(contactId);
      allow list: if isAdmin();
      allow update: if isAdmin() && isValidId(contactId) && isValidContact(incoming());
      allow delete: if isAdmin() && isValidId(contactId);
    }
    // Transactions / Payments
    function isValidTransaction(data) {
       return data.size() >= 3 && data.size() <= 20
         && data.keys().hasAll(['price', 'status'])
         && data.price is number && data.price >= 0;
    }

    match /transactions/{transactionId} {
      allow create: if true;
      allow read: if isAdmin() || (isSignedIn() && existing().userId == request.auth.uid);
      allow list: if isAdmin();
      allow get: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Settings
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Visitors Tracking
    match /visitors/{visitorId} {
      allow create, update: if true;
      allow read, delete: if isAdmin();
    }

    match /tracking_logs/{logId} {
      allow create: if true;
      allow read: if isAdmin();
    }

    // Payment Methods
    match /payment_methods/{methodId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Reviews
    match /reviews/{reviewId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Announcements
    match /announcements/{annId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Users
    match /users/{userId} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow write: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
    }

    // SEO Settings
    match /seo_settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Banners
    match /banners/{bannerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Media
    match /media/{mediaId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Notifications
    match /notifications/{noteId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Refunds
    match /refunds/{refundId} {
      allow create: if true;
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
  }
}
